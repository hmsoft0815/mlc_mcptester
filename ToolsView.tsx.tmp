import { useState, useEffect } from 'react';
import { useTranslation } from 'react-i18next';
import { chatClient } from '../api/ChatClient';
import type { McpProxyInternalMcpTool } from '../api/generated/mcp-proxy.schemas';
import {
  Server,
  Wrench,
  Search,
  Info,
  Zap,
  Power,
  ShieldAlert,
  ChevronRight,
  Loader2,
  X,
  EyeOff
} from 'lucide-react';
import ReactMarkdown from 'react-markdown';

interface Tool {
  name: string;
  description: string;
  inputSchema: any;
  alwaysOn?: boolean;
  disabled?: boolean;
  server: string;
}

/**
 * Converts generated tool format to legacy Tool interface.
 */
function convertTool(tool: McpProxyInternalMcpTool, serverName: string): Tool {
  return {
    name: tool.name || '',
    description: tool.description || '',
    inputSchema: tool.inputSchema || {},
    alwaysOn: tool.alwaysOn,
    disabled: tool.disabled,
    server: serverName
  };
}

export const ToolsView = () => {
  const { t } = useTranslation();
  const [tools, setTools] = useState<Record<string, Tool[]>>({});
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [selectedTool, setSelectedTool] = useState<Tool | null>(null);
  const [metadata, setMetadata] = useState<string | null>(null);
  const [loadingMetadata, setLoadingMetadata] = useState(false);
  const [config, setConfig] = useState<any>(null);
  const [filterAlwaysOn, setFilterAlwaysOn] = useState(false);
  const [hideTools, setHideTools] = useState(false);

  useEffect(() => {
    fetchData();
  }, []);

  const fetchData = async () => {
    setLoading(true);
    try {
      const toolData = await chatClient.listTools();
      // Convert generated tool format to legacy Tool format
      const convertedTools: Record<string, Tool[]> = {};
      for (const [serverName, serverTools] of Object.entries(toolData)) {
        convertedTools[serverName] = serverTools.map(tool => convertTool(tool, serverName));
      }
      setTools(convertedTools);
      const conf = await chatClient.getConfig();
      setConfig(conf);
    } catch (err) {
      console.error("Failed to fetch tools or config", err);
    } finally {
      setLoading(false);
    }
  };

  const handleToggle = async (tool: Tool, type: 'alwaysOn' | 'disabled') => {
    if (!config) return;

    const newConfig = { ...config };
    const srvName = tool.server;

    if (srvName === 'proxy') return; // Cannot disable proxy virtual tools easily

    if (!newConfig.mcpServers[srvName]) return;

    const srv = { ...newConfig.mcpServers[srvName] };

    if (type === 'disabled') {
      const disabled = srv.disabledTools || [];
      if (disabled.includes(tool.name)) {
        srv.disabledTools = disabled.filter((n: string) => n !== tool.name);
      } else {
        srv.disabledTools = [...disabled, tool.name];
        // If we disable it, it can't be alwaysOn
        srv.alwaysOnTools = (srv.alwaysOnTools || []).filter((n: string) => n !== tool.name);
      }
    } else if (type === 'alwaysOn') {
      const always = srv.alwaysOnTools || [];
      if (always.includes(tool.name)) {
        srv.alwaysOnTools = always.filter((n: string) => n !== tool.name);
      } else {
        srv.alwaysOnTools = [...always, tool.name];
        // If we make it always on, it can't be disabled
        srv.disabledTools = (srv.disabledTools || []).filter((n: string) => n !== tool.name);
      }
    }

    newConfig.mcpServers[srvName] = srv;
    setConfig(newConfig);

    try {
      await chatClient.saveConfig(newConfig);
      // Refresh tool list to show updated status from backend
      const toolData = await chatClient.listTools();
      const convertedTools: Record<string, Tool[]> = {};
      for (const [serverName, serverTools] of Object.entries(toolData)) {
        convertedTools[serverName] = serverTools.map(tool => convertTool(tool, serverName));
      }
      setTools(convertedTools);
    } catch (err) {
      console.error("Failed to save tool preference", err);
    }
  };

  const showDetails = async (tool: Tool) => {
    setSelectedTool(tool);
    setMetadata(null);
    setLoadingMetadata(true);
    try {
      const data = await chatClient.getToolMetadata(tool.name);
      setMetadata(data.content || null);
    } catch (err) {
      // Just log it, not all tools have MD documentation
      console.log("MetaData fetch skipped or failed", err);
    } finally {
      setLoadingMetadata(false);
    }
  };

  const filteredTools = Object.entries(tools).reduce((acc, [srv, srvTools]) => {
    const matched = srvTools.filter(t => {
      const matchesSearch = t.name.toLowerCase().includes(search.toLowerCase()) || 
                            t.description.toLowerCase().includes(search.toLowerCase());
      const matchesAlwaysOn = !filterAlwaysOn || t.alwaysOn;
      return matchesSearch && matchesAlwaysOn;
    });
    if (matched.length > 0) {
      acc[srv] = matched;
    }
    return acc;
  }, {} as Record<string, Tool[]>);

  if (loading) {
    return (
      <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', height: '100%', opacity: 0.6 }}>
        <Loader2 className="animate-spin" size={32} />
      </div>
    );
  }

  return (
    <div style={{ display: 'flex', height: 'calc(100vh - 60px)', overflow: 'hidden' }}>
      {/* Tool List Sidebar */}
      <div style={{
        flex: 1,
        overflowY: 'auto',
        padding: '2rem',
        borderRight: '1px solid var(--border-color)',
        backgroundColor: 'rgba(0,0,0,0.05)'
      }}>
        <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: '2rem', flexWrap: 'wrap', gap: '1rem' }}>
          <div>
            <h2 style={{ marginBottom: '0.25rem' }}>{t('tools.title')}</h2>
            <p style={{ color: 'var(--text-secondary)', fontSize: '0.9rem' }}>{t('tools.description')}</p>
          </div>
          <div style={{ display: 'flex', gap: '1.5rem', alignItems: 'center', flexWrap: 'wrap' }}>
            <label style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', cursor: 'pointer', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>
              <input type="checkbox" checked={filterAlwaysOn} onChange={(e) => setFilterAlwaysOn(e.target.checked)} />
              <Zap size={14} fill={filterAlwaysOn ? 'currentColor' : 'none'} color={filterAlwaysOn ? 'var(--accent-primary)' : 'currentColor'} />
              {t('tools.filterAlwaysOn', 'Nur Immer Aktiv')}
            </label>
            <label style={{ display: 'flex', alignItems: 'center', gap: '0.5rem', cursor: 'pointer', fontSize: '0.9rem', color: 'var(--text-secondary)' }}>
              <input type="checkbox" checked={hideTools} onChange={(e) => setHideTools(e.target.checked)} />
              <EyeOff size={14} />
              {t('tools.hideTools', 'Details ausblenden')}
            </label>
            <div style={{ position: 'relative' }}>
              <Search size={18} style={{ position: 'absolute', left: '10px', top: '50%', transform: 'translateY(-50%)', opacity: 0.5 }} />
              <input
                type="text"
                placeholder={t('tools.searchPlaceholder')}
                value={search}
                onChange={(e) => setSearch(e.target.value)}
                style={{
                  padding: '0.6rem 1rem 0.6rem 2.2rem',
                  background: 'var(--bg-secondary)',
                  border: '1px solid var(--border-color)',
                  borderRadius: '20px',
                  color: 'inherit',
                  width: '250px',
                  fontSize: '0.9rem'
                }}
              />
            </div>
          </div>
        </div>

        {Object.entries(filteredTools).map(([srv, srvTools]) => (
          <div key={srv} style={{ marginBottom: '2.5rem' }}>
            <h3 style={{
              display: 'flex',
              alignItems: 'center',
              gap: '10px',
              marginBottom: '1rem',
              fontSize: '1rem',
              opacity: 0.7,
              textTransform: 'uppercase',
              letterSpacing: '1px'
            }}>
              <Server size={18} /> {srv}
              <span style={{ fontSize: '0.75rem', opacity: 0.5, fontWeight: 'normal' }}>({srvTools.length})</span>
            </h3>

            {!hideTools && (
              <div style={{ display: 'grid', gridTemplateColumns: 'repeat(auto-fill, minmax(340px, 1fr))', gap: '1.2rem' }}>
                {srvTools.map(tool => (
                  <div
                    key={tool.name}
                    style={{
                      background: 'var(--bg-secondary)',
                      border: `1px solid ${selectedTool?.name === tool.name ? 'var(--accent-primary)' : 'var(--border-color)'}`,
                      borderRadius: '12px',
                      padding: '1.2rem',
                      transition: 'all 0.2s ease',
                      position: 'relative',
                      cursor: 'pointer',
                      boxShadow: selectedTool?.name === tool.name ? '0 0 15px rgba(255,255,255,0.05)' : 'none',
                      opacity: tool.disabled ? 0.6 : 1
                    }}
                    onClick={() => showDetails(tool)}
                  >
                    <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'flex-start', marginBottom: '0.8rem' }}>
                      <div style={{ display: 'flex', alignItems: 'center', gap: '10px' }}>
                        <div style={{
                          width: '32px',
                          height: '32px',
                          borderRadius: '8px',
                          backgroundColor: 'rgba(255,255,255,0.05)',
                          display: 'flex',
                          alignItems: 'center',
                          justifyContent: 'center'
                        }}>
                          <Wrench size={16} color="var(--accent-primary)" />
                        </div>
                        <strong style={{ fontSize: '1rem' }}>{tool.name.split('__')[1] || tool.name}</strong>
                      </div>
                      <div style={{ display: 'flex', gap: '8px' }}>
                        <button
                          onClick={(e) => { e.stopPropagation(); handleToggle(tool, 'alwaysOn'); }}
                          title={t('tools.alwaysOn')}
                          style={{
                            padding: '4px',
                            borderRadius: '6px',
                            background: tool.alwaysOn ? 'var(--accent-primary)' : 'transparent',
                            border: `1px solid ${tool.alwaysOn ? 'var(--accent-primary)' : 'rgba(255,255,255,0.1)'}`,
                            color: tool.alwaysOn ? '#000' : 'inherit',
                            cursor: 'pointer',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'center'
                          }}
                        >
                          <Zap size={14} fill={tool.alwaysOn ? 'currentColor' : 'none'} />
                        </button>
                        <button
                          onClick={(e) => { e.stopPropagation(); handleToggle(tool, 'disabled'); }}
                          title={t('tools.disabled')}
                          style={{
                            padding: '4px',
                            borderRadius: '6px',
                            background: tool.disabled ? 'var(--error-text)' : 'transparent',
                            border: `1px solid ${tool.disabled ? 'var(--error-text)' : 'rgba(255,255,255,0.1)'}`,
                            color: tool.disabled ? '#fff' : 'inherit',
                            cursor: 'pointer',
                            display: 'flex',
                            alignItems: 'center',
                            justifyContent: 'center'
                          }}
                        >
                          <Power size={14} />
                        </button>
                      </div>
                    </div>
                    <p style={{
                      fontSize: '0.85rem',
                      color: 'var(--text-secondary)',
                      lineHeight: '1.4',
                      display: '-webkit-box',
                      WebkitLineClamp: 2,
                      WebkitBoxOrient: 'vertical',
                      overflow: 'hidden',
                      marginBottom: '1rem',
                      minHeight: '2.4rem'
                    }}>
                      {tool.description}
                    </p>
                    <div style={{ display: 'flex', justifyContent: 'flex-end', opacity: 0.4 }}>
                      <ChevronRight size={16} />
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      {/* Tool Detail Panel */}
      <div style={{
        width: selectedTool ? '450px' : '0',
        borderLeft: selectedTool ? '1px solid var(--border-color)' : 'none',
        transition: 'width 0.3s ease',
        overflowY: 'auto',
        backgroundColor: 'var(--bg-primary)',
        padding: selectedTool ? '2rem' : '0'
      }}>
        {selectedTool && (
          <div style={{ minWidth: '380px' }}>
            <div style={{ display: 'flex', justifyContent: 'space-between', alignItems: 'center', marginBottom: '2rem' }}>
              <h3 style={{ display: 'flex', alignItems: 'center', gap: '10px' }}>
                <Info size={20} color="var(--accent-primary)" /> {t('tools.details')}
              </h3>
              <button
                onClick={() => setSelectedTool(null)}
                style={{ background: 'transparent', border: 'none', color: 'inherit', cursor: 'pointer', opacity: 0.5 }}
              >
                <X size={20} />
              </button>
            </div>

            <div style={{ marginBottom: '2rem' }}>
              <label style={{ fontSize: '0.75rem', textTransform: 'uppercase', opacity: 0.5, display: 'block', marginBottom: '0.5rem' }}>{t('tools.server')}</label>
              <div style={{ display: 'flex', alignItems: 'center', gap: '8px', color: 'var(--accent-primary)' }}>
                <Server size={14} /> <strong>{selectedTool.server}</strong>
              </div>
            </div>

            <div style={{ marginBottom: '2rem' }}>
              <label style={{ fontSize: '0.75rem', textTransform: 'uppercase', opacity: 0.5, display: 'block', marginBottom: '0.5rem' }}>{t('tools.documentation')}</label>
              <div style={{
                background: 'rgba(255,255,255,0.03)',
                padding: '1rem',
                borderRadius: '8px',
                border: '1px solid rgba(255,255,255,0.05)',
                fontSize: '0.9rem',
                lineHeight: '1.6'
              }}>
                {(() => {
                  if (loadingMetadata) {
                    return (
                      <div style={{ display: 'flex', alignItems: 'center', gap: '10px', opacity: 0.5 }}>
                        <Loader2 size={16} className="animate-spin" /> Fetching...
                      </div>
                    );
                  }
                  if (metadata) {
                    return (
                      <div className="markdown-content">
                        <ReactMarkdown>{metadata}</ReactMarkdown>
                      </div>
                    );
                  }
                  return (
                    <div style={{ display: 'flex', alignItems: 'center', gap: '10px', opacity: 0.5 }}>
                      <ShieldAlert size={16} /> {t('tools.noMetadata')}
                    </div>
                  );
                })()}
              </div>
            </div>

            <div>
              <label style={{ fontSize: '0.75rem', textTransform: 'uppercase', opacity: 0.5, display: 'block', marginBottom: '0.5rem' }}>{t('tools.inputSchema')}</label>
              <pre style={{
                background: '#000',
                padding: '1rem',
                borderRadius: '8px',
                fontSize: '0.8rem',
                overflowX: 'auto',
                color: '#a9b7c6',
                border: '1px solid rgba(255,255,255,0.1)'
              }}>
                {JSON.stringify(selectedTool.inputSchema, null, 2)}
              </pre>
            </div>
          </div>
        )}
      </div>
    </div>
  );
};
